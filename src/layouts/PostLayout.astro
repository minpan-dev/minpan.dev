---
import Layout from "./Layout.astro"
import Main from "./Main.astro"
import Header from "@/components/Header.tsx"
import Footer from "@/components/Footer.astro"
import BackToTop from "@/components/BackToTop.tsx"
import ScrollProgress from "@/components/ScrollProgress.tsx"
import BreadcrumbNav from "@/components/BreadcrumbNav.tsx"
import TableOfContents from "@/components/TableOfContents.astro"
import PrevNextNav from "@/components/PrevNextNav.tsx"
import ShareLinks from "@/components/ShareLinks.astro"
import EditPost from "@/components/EditPost.astro"
import Tag from "@/components/Tag.tsx"
import { formatDate } from "@/utils/formatDate"
import { getReadingTime } from "@/utils/getReadingTime"
import { SITE } from "@/config"
import { render } from "astro:content"
import type { CollectionEntry } from "astro:content"

interface Props {
  post: CollectionEntry<"blog">
  prevPost?: CollectionEntry<"blog"> | null
  nextPost?: CollectionEntry<"blog"> | null
}

const { post, prevPost = null, nextPost = null } = Astro.props
const { title, description, pubDatetime, modDatetime, tags, ogImage } =
  post.data

const { Content, headings } = await render(post)

const postUrl = new URL(`/posts/${post.id}/`, Astro.site ?? SITE.website).href
const resolvedOgImage = ogImage || `/posts/${post.id}/og.png`
const readingTime = getReadingTime(post.body ?? "")

const blogPostingSchema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: title,
  description,
  url: postUrl,
  datePublished: pubDatetime.toISOString(),
  ...(modDatetime ? { dateModified: modDatetime.toISOString() } : {}),
  image: new URL(resolvedOgImage, Astro.url.origin).href,
  author: {
    "@type": "Person",
    name: SITE.author,
    url: SITE.profile,
  },
  publisher: {
    "@type": "Person",
    name: SITE.author,
    url: SITE.website,
  },
  keywords: tags.join(", "),
}
---

<Layout title={title} description={description} ogImage={resolvedOgImage}>
  <Fragment slot="head">
    <script
      type="application/ld+json"
      set:html={JSON.stringify(blogPostingSchema)}
    />
  </Fragment>
  <ScrollProgress client:visible />
  <Header currentPath={Astro.url.pathname} client:load />
  <Main class="py-8" size="wide" pagefindBody>
    <BreadcrumbNav title={title} />

    <div class="flex gap-10">
      <article class="min-w-0 flex-1">
        <TableOfContents headings={headings} variant="mobile" />
        <header class="mb-8">
          <h1
            class="text-3xl font-bold tracking-tight text-foreground sm:text-4xl"
          >
            {title}
          </h1>
          <div
            class="mt-4 flex flex-wrap items-center gap-4 text-sm text-muted-foreground"
          >
            <time datetime={pubDatetime.toISOString()}>
              {formatDate(pubDatetime)}
            </time>
            <span>{readingTime} min read</span>
            {
              modDatetime && (
                <span>
                  (Updated:{" "}
                  <time datetime={modDatetime.toISOString()}>
                    {formatDate(modDatetime)}
                  </time>
                  )
                </span>
              )
            }
          </div>
          <div class="mt-4 flex flex-wrap gap-2">
            {tags.map((tag: string) => <Tag tag={tag} />)}
          </div>
        </header>

        <div
          class="prose max-w-none prose-neutral dark:prose-invert prose-headings:font-semibold prose-headings:tracking-tight prose-a:text-primary prose-a:underline-offset-4"
        >
          <Content />
        </div>

        <div class="mt-8 flex items-center justify-between">
          <EditPost postId={post.id} />
        </div>

        <ShareLinks title={title} url={postUrl} description={description} />
      </article>

      <TableOfContents headings={headings} variant="desktop" />
    </div>

    <PrevNextNav prevPost={prevPost} nextPost={nextPost} />
  </Main>
  <Footer />
  <BackToTop client:visible />
</Layout>

<style>
  .heading-anchor {
    opacity: 0;
    margin-left: 0.25rem;
    text-decoration: none;
    transition: opacity 0.15s;
  }
  :global(.prose) :is(h1, h2, h3, h4, h5, h6):hover .heading-anchor {
    opacity: 1;
  }
  .copy-code-btn {
    position: absolute;
    top: 0.5rem;
    right: 0.5rem;
    padding: 0.25rem;
    border-radius: 0.25rem;
    opacity: 0;
    transition: opacity 0.15s;
    z-index: 10;
  }
  :global(.prose) pre:hover .copy-code-btn {
    opacity: 1;
  }
</style>

<script>
  function setupHeadingAnchors() {
    const headings = document.querySelectorAll(
      ".prose h1[id], .prose h2[id], .prose h3[id], .prose h4[id], .prose h5[id], .prose h6[id]"
    )
    headings.forEach((heading) => {
      if (heading.querySelector(".heading-anchor")) return
      const link = document.createElement("a")
      link.href = `#${heading.id}`
      link.className = "heading-anchor text-muted-foreground"
      link.textContent = "#"
      link.setAttribute("aria-label", `Link to ${heading.textContent}`)
      heading.appendChild(link)
    })
  }

  function setupCopyCodeBlocks() {
    const codeBlocks = document.querySelectorAll(".prose pre")
    codeBlocks.forEach((pre) => {
      if (pre.querySelector(".copy-code-btn")) return
      pre.classList.add("relative")
      // Override Shiki's overflow-x:auto so the absolutely-positioned button
      // is never clipped. white-space:pre-wrap (also set by Shiki) handles wrapping.
      ;(pre as HTMLElement).style.overflowX = "visible"

      const btn = document.createElement("button")
      btn.className =
        "copy-code-btn bg-muted-foreground/10 text-muted-foreground hover:text-foreground"
      btn.setAttribute("aria-label", "Copy code")
      btn.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg>`

      btn.addEventListener("click", () => {
        const code = pre.querySelector("code")
        if (!code) return
        navigator.clipboard.writeText(code.textContent || "").then(() => {
          btn.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>`
          setTimeout(() => {
            btn.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg>`
          }, 2000)
        })
      })

      pre.appendChild(btn)
    })
  }

  setupHeadingAnchors()
  setupCopyCodeBlocks()
  document.addEventListener("astro:after-swap", () => {
    setupHeadingAnchors()
    setupCopyCodeBlocks()
  })
</script>
