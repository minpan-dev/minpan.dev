---
import type { CollectionEntry } from "astro:content"
import { getCollection } from "astro:content"
import Layout from "@/layouts/Layout.astro"
import Main from "@/layouts/Main.astro"
import Header from "@/components/Header.tsx"
import Footer from "@/components/Footer.astro"
import PostCard from "@/components/PostCard.astro"
import { groupBy } from "@/utils/groupBy"

type BlogPost = CollectionEntry<"blog">

const posts = await getCollection("blog")

const months = [
  "January",
  "February",
  "March",
  "April",
  "May",
  "June",
  "July",
  "August",
  "September",
  "October",
  "November",
  "December",
]
---

<Layout title="Posts">
  <Header currentPath={Astro.url.pathname} client:load />
  <Main>
    <section class="py-12">
      <h1
        class="mb-4 text-3xl font-bold tracking-tight text-foreground sm:text-4xl"
      >
        Posts
      </h1>
      <p class="mb-10 text-lg text-muted-foreground">
        All my articles, organized by date.
      </p>

      <div class="flex flex-col gap-12">
        {
          Object.entries(
            groupBy(posts, (post: BlogPost) =>
              post.data.pubDatetime.getFullYear()
            )
          )
            .sort(([yearA], [yearB]) => Number(yearB) - Number(yearA))
            .map(([year, yearGroup]) => (
              <div>
                <span class="text-2xl font-bold text-foreground">{year}</span>
                <sup class="ml-1 text-sm text-foreground">
                  {yearGroup.length}
                </sup>
                {Object.entries(
                  groupBy(
                    yearGroup,
                    (post: BlogPost) => post.data.pubDatetime.getMonth() + 1
                  )
                )
                  .sort(([monthA], [monthB]) => Number(monthB) - Number(monthA))
                  .map(([month, monthGroup]) => (
                    <div class="mb-8 flex flex-col last:mb-0 sm:flex-row">
                      <div class="mt-6 min-w-36 shrink-0 text-lg sm:mt-0">
                        <span class="font-bold text-foreground">
                          {months[Number(month) - 1]}
                        </span>
                        <sup class="ml-1 text-xs text-foreground">
                          {monthGroup.length}
                        </sup>
                      </div>
                      <div class="flex-1">
                        <ul class="grid gap-4">
                          {monthGroup
                            .sort(
                              (a, b) =>
                                Math.floor(
                                  b.data.pubDatetime.getTime() / 1000
                                ) -
                                Math.floor(a.data.pubDatetime.getTime() / 1000)
                            )
                            .map((post) => (
                              <PostCard post={post} />
                            ))}
                        </ul>
                      </div>
                    </div>
                  ))}
              </div>
            ))
        }
      </div>
    </section>
  </Main>
  <Footer />
</Layout>
