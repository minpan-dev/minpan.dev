---
import '@docsearch/css';
import Main from '@/layouts/Main.astro';
import Layout from '@/layouts/Layout.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import { useTranslations, getCurrentLocale, getLocaleStaticPaths } from '@/utils/i18n';
import { SITE } from '@/config';

export const getStaticPaths = getLocaleStaticPaths;

const locale = getCurrentLocale(Astro);
const t = useTranslations(locale);
---

<Layout title={`Search | ${t('site.title')}`}>
  <Header />
  <Main pageDesc={t('search.pageDesc')}>
    <div
      id="docsearch"
      transition:persist
      data-app-id={SITE.algolia.appId}
      data-api-key={SITE.algolia.apiKey}
      data-index-name={SITE.algolia.indexName}
      data-placeholder={t('search.placeholder')}
      class="flex justify-center"
    >
    </div>
  </Main>
  <Footer />
</Layout>

<script>
  import docsearch from '@docsearch/js';

  function initSearch() {
    const container = document.querySelector('#docsearch') as HTMLElement;
    if (!container) return;

    const { appId, apiKey, indexName, placeholder } = container.dataset;

    if (!appId || !apiKey || !indexName) {
      return;
    }

    docsearch({
      container: '#docsearch',
      appId,
      apiKey,
      indexName,
      placeholder: placeholder || 'Search documentation',
    });
  }

  document.addEventListener('astro:after-swap', initSearch);
  initSearch();
</script>

<style is:global>
  :root {
    --docsearch-primary-color: var(--accent);
    --docsearch-text-color: var(--foreground);
    --docsearch-spacing: 12px;
    --docsearch-icon-stroke-width: 1.4;
    --docsearch-highlight-color: var(--accent);
    --docsearch-muted-color: var(--muted-foreground);
    --docsearch-container-background: rgba(0, 0, 0, 0.5);
    --docsearch-modal-background: var(--background);
    --docsearch-modal-shadow: inset 1px 1px 0 0 var(--border), 0 3px 8px 0 var(--border);
    --docsearch-searchbox-background: var(--muted);
    --docsearch-searchbox-focus-background: var(--background);
    --docsearch-searchbox-shadow: inset 0 0 0 2px var(--accent);
    --docsearch-hit-color: var(--foreground);
    --docsearch-hit-active-color: var(--background);
    --docsearch-hit-background: var(--background);
    --docsearch-hit-shadow: none;
    --docsearch-key-gradient: linear-gradient(-225deg, var(--muted) 0%, var(--border) 100%);
    --docsearch-key-shadow:
      inset 0 -2px 0 0 var(--border), inset 0 0 1px 1px var(--background),
      0 1px 2px 1px rgba(30, 35, 90, 0.4);
    --docsearch-footer-background: var(--background);
    --docsearch-footer-shadow: 0 -1px 0 0 var(--border), 0 -3px 6px 0 rgba(0, 0, 0, 0.05);
  }

  /* Dark mode adjustments if needed, but variables should handle most of it */
  [data-theme='dark'] {
    --docsearch-container-background: rgba(0, 0, 0, 0.7);
    --docsearch-modal-shadow: inset 1px 1px 0 0 #2c2e40, 0 3px 8px 0 #000309;
    --docsearch-key-shadow:
      inset 0 -2px 0 0 #282d55, inset 0 0 1px 1px #515da4, 0 1px 2px 1px rgba(30, 35, 90, 0.4);
    --docsearch-footer-shadow: 0 -1px 0 0 #2c2e40, 0 -3px 6px 0 rgba(0, 0, 0, 0.05);
  }

  .DocSearch-Button {
    background: var(--muted);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 0 12px;
    height: 40px;
    width: 100%;
    max-width: 400px;
    margin: 0 auto;
  }

  .DocSearch-Button:hover {
    border-color: var(--accent);
    background: var(--background);
    box-shadow: none;
  }

  .DocSearch-Button-Placeholder {
    color: var(--muted-foreground);
    font-size: 0.9rem;
  }

  .DocSearch-Button .DocSearch-Search-Icon {
    color: var(--foreground);
  }

  .DocSearch-Button-Keys {
    display: flex;
  }
</style>
