---
import { DEFAULT_LOCALE, LOCALES_SETTING } from '@/constants';

const langs = Object.keys(LOCALES_SETTING);
const baseUrl = import.meta.env.PROD ? Astro.site?.pathname || '/' : '/';
const defaultLocale = DEFAULT_LOCALE;
---

<!doctype html>
<html lang={DEFAULT_LOCALE}>
  <head>
    <meta charset="UTF-8" />
    <title>404 Not Found</title>
    <meta name="robots" content="noindex" />

    <script is:inline define:vars={{ langs, baseUrl, defaultLocale }}>
      const findLocale = (lang) => {
        if (!lang) return null;
        const lowerLang = lang.toLowerCase();
        return (
          // @ts-expect-error: langs is injected via define:vars
          langs.find((l) => l.toLowerCase() === lowerLang) ||
          // @ts-expect-error: langs is injected via define:vars
          langs.find((l) => l.toLowerCase() === lowerLang.split('-')[0])
        );
      };

      const savedLang = localStorage.selectedLang;
      const browserLang = navigator.language;

      const targetLang = findLocale(savedLang) || findLocale(browserLang) || defaultLocale;
      const cleanBase = baseUrl.endsWith('/') ? baseUrl : baseUrl + '/';

      // Look at the attempted path and construct the new 404 redirect with the correct language
      location.replace(`${cleanBase}${targetLang}/404/`);
    </script>
  </head>
  <body style="background: #fdfdfd;">
    <h1>404 Not Found</h1>
    <script is:inline>
      if (localStorage.getItem('theme') === 'dark') {
        document.body.style.background = '#212737';
      }
    </script>
  </body>
</html>
