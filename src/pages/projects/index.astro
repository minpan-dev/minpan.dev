---
import Layout from "@/layouts/Layout.astro"
import Main from "@/layouts/Main.astro"
import Header from "@/components/Header.tsx"
import Footer from "@/components/Footer.astro"
import { PROJECTS } from "@/config"
import {
  Card,
  CardHeader,
  CardTitle,
  CardDescription,
  CardFooter,
} from "@/components/ui/card"
---

<Layout title="Projects">
  <Header currentPath={Astro.url.pathname} client:load />
  <Main>
    <section class="py-12">
      <h1
        class="mb-4 text-3xl font-bold tracking-tight text-foreground sm:text-4xl"
      >
        Projects
      </h1>
      <p class="mb-10 text-lg text-muted-foreground">
        Open source projects I've built and maintain on GitHub.
      </p>

      <div class="grid gap-4 sm:grid-cols-2">
        {
          PROJECTS.map((project) => (
            <a
              href={project.href}
              target="_blank"
              rel="noopener noreferrer"
              class="group block"
            >
              <Card className="h-full transition-colors group-hover:ring-primary/30">
                <CardHeader>
                  <CardTitle className="flex items-center gap-2 text-base font-semibold tracking-tight text-foreground transition-colors group-hover:text-primary">
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      width="16"
                      height="16"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      aria-hidden="true"
                      class="shrink-0 text-muted-foreground"
                    >
                      <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4" />
                      <path d="M9 18c-4.51 2-5-2-7-2" />
                    </svg>
                    {project.name}
                  </CardTitle>
                  <CardDescription>{project.description}</CardDescription>
                </CardHeader>
                <CardFooter className="flex flex-wrap items-center gap-3">
                  {project.language && (
                    <span class="flex items-center gap-1.5 text-xs text-muted-foreground">
                      <span class="inline-block size-3 rounded-full bg-foreground/30" />
                      {project.language}
                    </span>
                  )}
                  {project.tags && project.tags.length > 0 && (
                    <div class="flex flex-wrap gap-1.5">
                      {project.tags.map((tag) => (
                        <span class="inline-flex h-5 items-center rounded-full border border-border px-2 text-xs font-medium text-foreground">
                          {tag}
                        </span>
                      ))}
                    </div>
                  )}
                </CardFooter>
              </Card>
            </a>
          ))
        }
      </div>
    </section>
  </Main>
  <Footer />
</Layout>
