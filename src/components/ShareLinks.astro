---
interface Props {
  title: string
  url: string
  description?: string
}

const { title, url, description = "" } = Astro.props
import { SiGmail, SiInstagram, SiReddit, SiX } from "react-icons/si"

const encodedTitle = encodeURIComponent(title)
const encodedUrl = encodeURIComponent(url)
const encodedDesc = encodeURIComponent(description)

const links = [
  {
    name: "X",
    href: `https://x.com/intent/tweet?text=${encodedTitle}&url=${encodedUrl}`,
    icon: SiX,
  },
  {
    name: "Instagram",
    href: `https://www.instagram.com/sharing/share-offsite/?url=${encodedUrl}`,
    icon: SiInstagram,
  },
  {
    name: "Reddit",
    href: `https://www.reddit.com/submit?title=${encodedTitle}&url=${encodedUrl}`,
    icon: SiReddit,
  },
  {
    name: "Gmail",
    href: `mailto:?subject=${encodedTitle}&body=${encodedDesc}%0A%0A${encodedUrl}`,
    icon: SiGmail,
  },
]
---

<div class="mt-8 border-t border-border pt-6">
  <span class="text-sm text-muted-foreground">Share this post:</span>
  <ul aria-label="Share options" class="mt-3 flex items-center gap-3">
    {
      links.map((link) => {
        const Icon = link.icon

        return (
          <li>
            <a
              href={link.href}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center justify-center rounded-md border border-border p-2 text-muted-foreground transition-colors hover:bg-accent hover:text-accent-foreground"
              aria-label={`Share on ${link.name}`}
            >
              <Icon size={16} aria-hidden="true" />
            </a>
          </li>
        )
      })
    }
  </ul>
</div>
